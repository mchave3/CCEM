<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="CCEM.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:dev="using:DevWinUI"
        xmlns:local="using:CCEM"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <TitleBar x:Name="AppTitleBar"
                  Title="{x:Bind dev:ProcessInfoHelper.ProductName}"
                  IsBackButtonVisible="True"
                  IsPaneToggleButtonVisible="True"
                  Subtitle="{x:Bind dev:ProcessInfoHelper.VersionWithPrefix}">
            <AutoSuggestBox MinWidth="320"
                            VerticalAlignment="Center"
                            PlaceholderText="Search"
                            QueryIcon="Find"
                            QuerySubmitted="OnQuerySubmitted"
                            TextChanged="OnTextChanged" />
            <!--  Temporary Fix TitleBar Icon  -->
            <TitleBar.LeftHeader>
                <ImageIcon Width="16"
                           Height="16"
                           Margin="2,0,14,0"
                           Source="ms-appx:///Assets/AppIcon.png" />
            </TitleBar.LeftHeader>
            <TitleBar.RightHeader>
                <Button x:Name="ThemeButton"
                        Height="32"
                        Margin="0,0,4,0"
                        Click="ThemeButton_Click"
                        Content="{dev:FontIcon GlyphCode=E793,
                                               FontSize=16}"
                        Style="{ThemeResource SubtleButtonStyle}"
                        ToolTipService.ToolTip="Toggle Theme" />
            </TitleBar.RightHeader>
        </TitleBar>
        <NavigationView x:Name="NavView"
                        Grid.Row="1"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False">
            <NavigationView.Header>
                <StackPanel Spacing="12">
                    <dev:BreadcrumbNavigator x:Name="BreadCrumbNav" />
                    <CommandBar x:Name="GlobalCommandBar"
                                DefaultLabelPosition="Right"
                                Background="Transparent">
                        <AppBarButton Icon="Contact"
                                      Label="Connection"
                                      Command="{x:Bind ViewModel.NavigateToConnectionCommand}" />
                        <AppBarButton Icon="Disconnect"
                                      Label="Disconnect"
                                      Command="{x:Bind ViewModel.DisconnectCommand}" />
                        <AppBarSeparator />
                        <AppBarButton x:Name="PluginsButton"
                                      Label="Plugins"
                                      ToolTipService.ToolTip="Launch SCCM tools">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE90F;" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <CommandBar.Content>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                <FontIcon Glyph="{x:Bind ViewModel.ConnectionStatusGlyph, Mode=OneWay}"
                                          Foreground="{x:Bind ViewModel.ConnectionStatusBrush, Mode=OneWay}" />
                                <TextBlock Text="{x:Bind ViewModel.ConnectionStatusText, Mode=OneWay}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </CommandBar.Content>
                    </CommandBar>
                </StackPanel>
            </NavigationView.Header>
            <Frame x:Name="NavFrame" />
        </NavigationView>
    </Grid>
</Window>

