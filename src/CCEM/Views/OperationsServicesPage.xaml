<Page
    x:Class="CCEM.Views.OperationsServicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:CCEM.ViewModels.Sccm"
    xmlns:models="using:CCEM.Core.Sccm.Models"
    mc:Ignorable="d"
    x:DataType="vm:OperationsServicesViewModel">

    <Grid Padding="20">
        <StackPanel Spacing="12">
            <TextBlock Text="Services"
                       FontSize="24"
                       FontWeight="SemiBold" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Width="220"
                         Header="Target host"
                         Text="{x:Bind TargetHost, Mode=TwoWay}" />
                <TextBox Width="90"
                         Header="Port"
                         Text="{x:Bind Port, Mode=TwoWay}" />
                <ToggleSwitch Header="SSL"
                              IsOn="{x:Bind UseSsl, Mode=TwoWay}" />
                <Button Content="Refresh"
                        Click="OnRefreshClicked" />
            </StackPanel>

            <ProgressRing IsActive="{x:Bind IsLoading, Mode=OneWay}" />
            <TextBlock Foreground="Red"
                       Text="{x:Bind Error, Mode=OneWay}" />

            <ListView ItemsSource="{x:Bind Services}"
                      SelectionMode="None">
                <ListView.Header>
                    <StackPanel Orientation="Horizontal" Spacing="24">
                        <TextBlock Text="Name" Width="220" FontWeight="SemiBold" />
                        <TextBlock Text="Display name" Width="240" FontWeight="SemiBold" />
                        <TextBlock Text="Status" Width="140" FontWeight="SemiBold" />
                        <TextBlock Text="Startup" FontWeight="SemiBold" />
                    </StackPanel>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:SccmServiceStatus">
                        <StackPanel Orientation="Horizontal" Spacing="24">
                            <TextBlock Text="{x:Bind Name}" Width="220" />
                            <TextBlock Text="{x:Bind DisplayName}" Width="240" />
                            <TextBlock Text="{x:Bind Status}" Width="140" />
                            <TextBlock Text="{x:Bind StartupAutomatic}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Page>
