<Page
    x:Class="CCEM.Views.InventoryCachePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:CCEM.ViewModels.Sccm"
    xmlns:models="using:CCEM.Core.Sccm.Models"
    mc:Ignorable="d"
    x:DataType="vm:InventoryCacheViewModel">

    <Grid Padding="20">
        <StackPanel Spacing="12">
            <TextBlock Text="Cache"
                       FontSize="24"
                       FontWeight="SemiBold" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Width="220"
                         Header="Target host"
                         Text="{x:Bind TargetHost, Mode=TwoWay}" />
                <TextBox Width="90"
                         Header="Port"
                         Text="{x:Bind Port, Mode=TwoWay}" />
                <ToggleSwitch Header="SSL"
                              IsOn="{x:Bind UseSsl, Mode=TwoWay}" />
                <Button Content="Refresh"
                        Click="OnRefreshClicked" />
            </StackPanel>

            <ProgressRing IsActive="{x:Bind IsLoading, Mode=OneWay}" />
            <TextBlock Foreground="Red"
                       Text="{x:Bind Error, Mode=OneWay}" />

            <ListView ItemsSource="{x:Bind CacheEntries}"
                      SelectionMode="None">
                <ListView.Header>
                    <StackPanel Orientation="Horizontal" Spacing="24">
                        <TextBlock Text="ContentId" Width="180" FontWeight="SemiBold" />
                        <TextBlock Text="Path" Width="260" FontWeight="SemiBold" />
                        <TextBlock Text="Size (MB)" Width="120" FontWeight="SemiBold" />
                        <TextBlock Text="Persisted" FontWeight="SemiBold" />
                    </StackPanel>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:SccmCacheEntry">
                        <StackPanel Orientation="Horizontal" Spacing="24">
                            <TextBlock Text="{x:Bind ContentId}" Width="180" />
                            <TextBlock Text="{x:Bind Location}" Width="260" />
                            <TextBlock Text="{x:Bind SizeMb}" Width="120" />
                            <TextBlock Text="{x:Bind Persisted}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Page>
